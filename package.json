{
    "name": "5s-excellence",
    "version": "2.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "db:env": "node -e \"require('./prisma/load-env.js')\"",
        "db:generate": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js generate",
        "db:push": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js db push",
        "db:migrate": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js migrate dev",
        "db:seed": "node -r ./prisma/load-env.js node_modules/tsx/dist/cli.mjs prisma/seed.ts",
        "db:studio": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js studio",
        "db:reset": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js migrate reset --force && node -r ./prisma/load-env.js node_modules/tsx/dist/cli.mjs prisma/seed.ts",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "next": "^15.1.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@prisma/client": "^6.2.0",
        "next-auth": "^5.0.0-beta.25",
        "@auth/prisma-adapter": "^2.7.4",
        "bcryptjs": "^2.4.3",
        "recharts": "^2.15.0",
        "lucide-react": "^0.468.0",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "papaparse": "^5.4.1",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/papaparse": "^5.3.15",
        "prisma": "^6.2.0",
        "tsx": "^4.19.0",
        "tailwindcss": "^3.4.17",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.4.49",
        "eslint": "^9.17.0",
        "eslint-config-next": "^15.1.0"
    }
}