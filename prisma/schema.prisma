// prisma/schema.prisma
// 5S Excellence & Suggestions — Complete Data Model
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  employe
  superviseur
  direction
  admin
}

enum UserStatus {
  actif
  inactif
}

enum EvalStatus {
  brouillon
  soumise
  analysee
  revue_superviseur
  cloturee
}

enum SuggestionStatus {
  brouillon
  soumise
  analysee
  en_revue
  a_preciser
  retenue
  rejetee
  planifiee
  en_cours
  mise_en_oeuvre
  cloturee
}

enum ActionStatus {
  ouverte
  en_cours
  terminee
  annulee
}

enum Priority {
  basse
  moyenne
  haute
  critique
}

enum Urgency {
  faible
  moyenne
  haute
  critique
}

enum Impact {
  faible
  moyen
  fort
  tres_fort
}

enum Feasibility {
  facile
  moderee
  complexe
  difficile
}

enum IASource {
  local
  api
}

// ============================================================
// CORE ENTITIES
// ============================================================

model User {
  id            String     @id @default(cuid())
  matricule     String     @unique
  nom           String
  prenom        String
  email         String?    @unique
  password      String     // bcrypt hashed
  role          Role       @default(employe)
  service       Service?   @relation(fields: [serviceId], references: [id])
  serviceId     String?
  atelier       Atelier?   @relation(fields: [atelierId], references: [id])
  atelierId     String?
  fonction      String     @default("Agent")
  telephone     String?
  photo         String?    // URL or path
  statut        UserStatus @default(actif)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  evaluations       Evaluation[]
  suggestions       Suggestion[]
  badgesAttribues    BadgeAttribue[]
  actionsResponsable Action[]        @relation("ActionResponsable")

  // NextAuth
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Service {
  id        String   @id @default(cuid())
  nom       String   @unique
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  users       User[]
  evaluations Evaluation[]
  suggestions Suggestion[]

  @@map("services")
}

model Atelier {
  id        String   @id @default(cuid())
  nom       String   @unique
  serviceId String?
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  users       User[]
  evaluations Evaluation[] @relation("EvalZone")

  @@map("ateliers")
}

// ============================================================
// 5S EVALUATION
// ============================================================

model Evaluation {
  id                  String     @id @default(cuid())
  user                User       @relation(fields: [userId], references: [id])
  userId              String
  date                DateTime
  service             Service    @relation(fields: [serviceId], references: [id])
  serviceId           String
  zone                Atelier    @relation("EvalZone", fields: [zoneId], references: [id])
  zoneId              String
  commentaireGeneral  String?

  // Scores par pilier (sur 20)
  scoreSeiri          Int?
  scoreSeiton         Int?
  scoreSeiso          Int?
  scoreSeiketsu       Int?
  scoreShitsuke       Int?
  scoreTotal          Int?       // sur 100

  // Appréciation
  appreciation        String?

  // Analyse IA
  commentaireIA       String?    @db.Text
  forces              String[]
  faiblesses          String[]
  actionsRecommandees String[]
  syntheseManageriale String?    @db.Text
  niveauPriorite      Priority?
  iaSource            IASource   @default(local)

  // Réponses détaillées (JSON)
  reponses            Json?      // { "seiri_0": 4, "seiri_1": 3, ... }
  commentairesQuestions Json?    // { "seiri_0": "...", ... }

  // Photos
  photos              Photo[]

  statut              EvalStatus @default(brouillon)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Actions liées
  actions             Action[]   @relation("ActionEval")

  @@index([userId])
  @@index([serviceId])
  @@index([date])
  @@map("evaluations")
}

// ============================================================
// SUGGESTIONS
// ============================================================

model Suggestion {
  id                    String           @id @default(cuid())
  user                  User             @relation(fields: [userId], references: [id])
  userId                String
  date                  DateTime
  titre                 String
  categorie             Categorie        @relation(fields: [categorieId], references: [id])
  categorieId           String
  serviceConcerne       Service?         @relation(fields: [serviceConcerneId], references: [id])
  serviceConcerneId     String?
  lieu                  String?
  probleme              String           @db.Text
  suggestion            String           @db.Text
  benefices             String           @db.Text
  urgence               Urgency?
  impactEstime          Impact?
  faisabiliteEstimee    Feasibility?
  coutEstime            String?
  delaiEstime           String?

  // Scoring (sur 100)
  scoreClarte           Int?
  scorePertinence       Int?
  scoreFaisabilite      Int?
  scoreImpact           Int?
  scoreOriginalite      Int?
  scoreDetail           Int?
  scoreTotal            Int?

  // Appréciation
  appreciation          String?

  // Analyse IA
  commentaireIA         String?          @db.Text
  forces                String[]
  limites               String[]
  actionsRecommandees   String[]
  syntheseManageriale   String?          @db.Text
  potentielMiseEnOeuvre String?
  niveauPriorite        Priority?
  iaSource              IASource         @default(local)

  // Workflow
  avisSuperviseur       String?
  commentaireSuperviseur String?         @db.Text
  decisionDirection     String?
  commentaireDirection  String?          @db.Text

  // Photos
  photos                Photo[]

  statut                SuggestionStatus @default(brouillon)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Actions liées
  actions               Action[]         @relation("ActionSugg")

  @@index([userId])
  @@index([categorieId])
  @@index([date])
  @@map("suggestions")
}

model Categorie {
  id        String   @id @default(cuid())
  nom       String   @unique
  icone     String   @default("📌")
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  suggestions Suggestion[]

  @@map("categories")
}

// ============================================================
// ACTIONS CORRECTIVES
// ============================================================

model Action {
  id            String       @id @default(cuid())
  description   String       @db.Text
  responsable   User?        @relation("ActionResponsable", fields: [responsableId], references: [id])
  responsableId String?
  echeance      DateTime?
  statut        ActionStatus @default(ouverte)
  priorite      Priority     @default(moyenne)
  avancement    Int          @default(0) // 0-100
  origineType   String?      // "5S", "suggestion", "autre"

  // Relations optionnelles vers l'origine
  evaluation    Evaluation?  @relation("ActionEval", fields: [evaluationId], references: [id])
  evaluationId  String?
  suggestion    Suggestion?  @relation("ActionSugg", fields: [suggestionId], references: [id])
  suggestionId  String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([responsableId])
  @@index([statut])
  @@map("actions")
}

// ============================================================
// BADGES & RÉCOMPENSES
// ============================================================

model Badge {
  id        String  @id @default(cuid())
  code      String  @unique // "champion_5s", "idee_utile", etc.
  label     String
  icone     String
  condition String
  type      String  // "5S" ou "suggestion"
  actif     Boolean @default(true)

  attribues BadgeAttribue[]

  @@map("badges")
}

model BadgeAttribue {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  badgeId   String
  periode   String?
  raison    String?
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("badges_attribues")
}

// ============================================================
// PHOTOS / PIÈCES JOINTES
// ============================================================

model Photo {
  id            String      @id @default(cuid())
  url           String
  filename      String?
  mimeType      String?
  evaluation    Evaluation? @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluationId  String?
  suggestion    Suggestion? @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  suggestionId  String?
  createdAt     DateTime    @default(now())

  @@map("photos")
}

// ============================================================
// CONFIGURATION
// ============================================================

model Config {
  id    String @id @default(cuid())
  cle   String @unique
  valeur Json

  @@map("config")
}

// ============================================================
// PERMISSIONS
// ============================================================

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique   // ex: "eval_create", "suggestion_view", "admin_users"
  label       String              // ex: "Créer une évaluation"
  description String?
  module      String              // ex: "evaluations", "suggestions", "admin", "actions", "dashboard"
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId])
  @@map("role_permissions")
}

// ============================================================
// NEXT-AUTH TABLES
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
